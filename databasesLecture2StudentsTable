CREATE TABLE students(
    stdNumber NUMBER(2) PRIMARY KEY,
    stdName VARCHAR2(10) NOT NULL UNIQUE,
    major VARCHAR2(5),
    stdAverage NUMBER(5, 2) CHECK(stdAverage >= 50)
);

